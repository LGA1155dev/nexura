<!DOCTYPE html>
<html lang="pt-BR">
<head>
<%- include('partials/head') %>
</head>
<body>
<div class="auth-shell">
  <div class="auth-card">
    <div class="auth-brand"><span class="mark">ND</span><span>Nexura Desk</span></div>
    <h1>Redefinir senha</h1>
    <p class="auth-sub">Crie uma nova senha para sua conta.</p>

    <% if (error) { %><div class="error-banner"><%= error %></div><% } %>

    <form method="POST" action="/reset-password">
      <input type="hidden" name="token" value="<%= token %>">
      <div class="field">
        <label>Nova senha</label>
        <input type="password" name="password" required minlength="8">
      </div>
      <button class="btn btn-accent btn-block" type="submit">Redefinir senha</button>
    </form>

    <p class="auth-foot"><a href="/login">Voltar ao login</a></p>
  </div>
</div>
</body>
</html>
