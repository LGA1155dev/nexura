<!DOCTYPE html>
<html lang="pt-BR">
<head>
<%- include('head') %>
</head>
<body>
<div class="app-shell">
  <aside class="sidebar">
    <div class="brand"><span class="mark">ND</span><span>Nexura Desk</span></div>

    <div class="nav-group">
      <div class="nav-label">Geral</div>
      <a class="nav-item <%= active === 'dashboard' ? 'active' : '' %>" href="/dashboard">Painel</a>
      <a class="nav-item <%= active === 'tickets' ? 'active' : '' %>" href="/tickets">Chamados</a>
      <a class="nav-item <%= active === 'billing' ? 'active' : '' %>" href="/billing">Plano</a>
      <a class="nav-item <%= active === 'profile' ? 'active' : '' %>" href="/profile">Meu perfil</a>
    </div>

    <% if (currentUser && (currentUser.role === 'agent' || currentUser.role === 'admin')) { %>
    <div class="nav-group">
      <div class="nav-label">Equipe</div>
      <a class="nav-item <%= active === 'activity' ? 'active' : '' %>" href="/admin/activity">Atividade recente</a>
    </div>
    <% } %>

    <% if (currentUser && currentUser.role === 'admin') { %>
    <div class="nav-group">
      <div class="nav-label">Administração</div>
      <a class="nav-item <%= active === 'admin' ? 'active' : '' %>" href="/admin">Visão geral</a>
      <a class="nav-item <%= active === 'admin-users' ? 'active' : '' %>" href="/admin/users">Usuários</a>
    </div>
    <% } %>

    <div class="sidebar-foot">
      <div class="sidebar-user">
        <div class="avatar" style="background: <%= currentUser.avatar_color %>"><%= currentUser.name.charAt(0).toUpperCase() %></div>
        <div>
          <div class="sidebar-user-name"><%= currentUser.name %></div>
          <div class="sidebar-user-role"><%= currentUser.role %></div>
        </div>
      </div>
      <form class="logout-form" method="POST" action="/logout">
        <button type="submit">Sair da conta</button>
      </form>
    </div>
  </aside>

  <div class="main">
    <div class="topbar">
      <h1><%= title %></h1>
    </div>
    <div class="content">
