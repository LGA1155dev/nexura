<%- include('partials/app-header', {active: 'tickets'}) %>

<div class="ticket-header">
  <div>
    <h1><%= ticket.subject %></h1>
    <div class="ticket-meta">
      <span class="ticket-id mono">NXD-<%= String(ticket.id).padStart(5,'0') %></span>
      <span>·</span>
      <span><%= ticket.owner_name %></span>
      <span>·</span>
      <span><%= ticket.category %></span>
      <span>·</span>
      <span><%= ticket.created_at %></span>
    </div>
  </div>
  <div style="display:flex; gap:8px; align-items:center;">
    <span class="badge badge-<%= ticket.priority %>"><%= ticket.priority %></span>
    <span class="badge badge-<%= ticket.status %>"><%= ticket.status.replace('_',' ') %></span>
  </div>
</div>

<div class="card card-pad" style="margin-bottom:18px;">
  <div style="white-space:pre-wrap; font-size:13.5px;"><%= ticket.description %></div>
</div>

<% if (isStaff) { %>
<div class="card card-pad" style="margin-bottom:18px; display:flex; gap:10px; align-items:center;">
  <form method="POST" action="/tickets/<%= ticket.id %>/status" style="display:flex; gap:8px; align-items:center;">
    <label style="font-size:12.5px; color:#5B6472;">Status:</label>
    <select name="status" onchange="this.form.submit()">
      <option value="open" <%= ticket.status === 'open' ? 'selected' : '' %>>Aberto</option>
      <option value="in_progress" <%= ticket.status === 'in_progress' ? 'selected' : '' %>>Em andamento</option>
      <option value="closed" <%= ticket.status === 'closed' ? 'selected' : '' %>>Fechado</option>
    </select>
  </form>
</div>
<% } %>

<div class="section-title">Anexos</div>
<div class="card card-pad" style="margin-bottom:18px;">
  <% if (attachments.length === 0) { %>
    <p style="color:#5B6472; font-size:13px; margin:0 0 12px;">Nenhum anexo enviado.</p>
  <% } %>
  <% attachments.forEach(function(a) { %>
    <div class="attachment-row">
      <span>📎</span>
      <a href="/uploads/<%= a.stored_name %>" target="_blank"><%= a.original_name %></a>
      <span class="mono" style="color:#5B6472; font-size:11.5px;"><%= a.created_at %></span>
    </div>
  <% }) %>
  <form method="POST" action="/tickets/<%= ticket.id %>/attachments" enctype="multipart/form-data" style="margin-top:10px; display:flex; gap:8px; align-items:center;">
    <input type="file" name="file" required>
    <button class="btn btn-ghost btn-sm" type="submit">Enviar anexo</button>
  </form>
</div>

<div class="section-title">Comentários</div>
<div class="card card-pad">
  <% comments.forEach(function(c) { %>
    <div class="comment">
      <div class="comment-head">
        <span class="comment-author"><%= c.author_name %></span>
        <% if (c.author_role !== 'user') { %><span class="badge badge-open" style="font-size:10px;"><%= c.author_role %></span><% } %>
        <span class="comment-time">· <%= c.created_at %></span>
      </div>
      <div class="comment-body"><%= c.body %></div>
    </div>
  <% }) %>

  <form method="POST" action="/tickets/<%= ticket.id %>/comments" style="margin-top:14px;">
    <div class="field">
      <textarea name="body" rows="3" placeholder="Escreva um comentário..." required></textarea>
    </div>
    <button class="btn btn-accent btn-sm" type="submit">Comentar</button>
  </form>
</div>

<%- include('partials/app-footer') %>
