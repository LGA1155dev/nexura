<!DOCTYPE html>
<html lang="pt-BR">
<head>
<%- include('partials/head') %>
</head>
<body>
<div class="auth-shell">
  <div class="auth-card">
    <div class="auth-brand"><span class="mark">ND</span><span>Nexura Desk</span></div>
    <h1>Recuperar senha</h1>
    <p class="auth-sub">Informe seu e-mail para receber instruções de redefinição.</p>

    <% if (error) { %><div class="error-banner"><%= error %></div><% } %>
    <% if (sent) { %>
      <div class="success-banner">Se este e-mail estiver cadastrado, enviaremos um link de redefinição em instantes.</div>
    <% } else { %>
      <form method="POST" action="/forgot-password">
        <div class="field">
          <label>E-mail</label>
          <input type="email" name="email" required autofocus>
        </div>
        <button class="btn btn-accent btn-block" type="submit">Enviar instruções</button>
      </form>
    <% } %>

    <p class="auth-foot"><a href="/login">Voltar ao login</a></p>
  </div>
</div>
</body>
</html>
