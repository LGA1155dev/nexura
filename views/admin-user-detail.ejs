<%- include('partials/app-header', {active: 'admin-users'}) %>

<div class="card card-pad" style="max-width:480px; margin-bottom:18px;">
  <div class="section-title" style="margin-top:0;">Informações</div>
  <p style="margin:0 0 4px; font-size:13.5px;"><strong><%= viewedUser.name %></strong></p>
  <p style="margin:0 0 4px; font-size:13px; color:#5B6472;"><%= viewedUser.email %></p>
  <p style="margin:0 0 12px; font-size:13px; color:#5B6472;"><%= viewedUser.department %></p>

  <form method="POST" action="/admin/users/<%= viewedUser.id %>/role" style="display:flex; gap:8px; align-items:center;">
    <label style="font-size:12.5px; color:#5B6472;">Papel:</label>
    <select name="role" onchange="this.form.submit()">
      <option value="user" <%= viewedUser.role === 'user' ? 'selected' : '' %>>Usuário</option>
      <option value="agent" <%= viewedUser.role === 'agent' ? 'selected' : '' %>>Agente</option>
      <option value="admin" <%= viewedUser.role === 'admin' ? 'selected' : '' %>>Administrador</option>
    </select>
  </form>
</div>

<div class="section-title">Chamados abertos por este usuário</div>
<div class="card">
  <table>
    <thead><tr><th>ID</th><th>Assunto</th><th>Status</th><th>Criado em</th></tr></thead>
    <tbody>
      <% if (tickets.length === 0) { %><tr><td colspan="4" style="text-align:center; color:#5B6472; padding:20px;">Nenhum chamado.</td></tr><% } %>
      <% tickets.forEach(function(t) { %>
        <tr onclick="window.location='/tickets/<%= t.id %>'" style="cursor:pointer;">
          <td class="ticket-id">NXD-<%= String(t.id).padStart(5,'0') %></td>
          <td><%= t.subject %></td>
          <td><span class="badge badge-<%= t.status %>"><%= t.status.replace('_',' ') %></span></td>
          <td class="mono" style="font-size:12px; color:#5B6472;"><%= t.created_at %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('partials/app-footer') %>
